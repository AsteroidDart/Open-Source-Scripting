# Date of completion: 22 May 2026
# How to run this script: ./clean trending_videos_unclean.csv
#
# Summary:
# This script performs data cleaning on a CSV file containing
# YouTube trending video data.
#
# It performs the following:
# - Error checks for:
#   * missing input file
#   * missing file in directory
#   * incorrect file format
#   * empty file
#   * incorrect number of columns
#
# - Data cleaning operations:
#   * removes ratings_disabled column
#   * removes rows with incorrect columns
#   * removes rows with missing values
#   * removes duplicate rows
#   * removes rows with 0 likes/dislikes
#   * removes time from publish_date
#   * converts TRUE/FALSE to True/False
#
# Output:
# trending_videos_clean.csv

# ERROR CHECKS

# 1) No input file specified
if [ $# -eq 0 ]; then
    echo "ERROR: No input CSV file provided"
    exit 1
fi

INPUT_FILE="$1"

# 2) Input file not found
if [ ! -f "$INPUT_FILE" ]; then
    echo "ERROR: Input file not found in the current directory"
    exit 1
fi

# 3) Input file is not CSV
if [[ "$INPUT_FILE" != *.csv ]]; then
    echo "ERROR: Input file expected in a CSV format"
    exit 1
fi

# 4) Input file is empty
if [ ! -s "$INPUT_FILE" ]; then
    echo "ERROR: Empty file provided"
    exit 1
fi

# 5) Input CSV file has incorrect number of columns
INVALID_COLS=$(awk -F',' 'NF != 7 {print NR}' "$INPUT_FILE")

if [ ! -z "$INVALID_COLS" ]; then
    echo "ERROR: Expected 7 columns in the input"
    exit 1
fi

# DATA CLEANING

OUTPUT_FILE="trending_videos_clean.csv"

awk -F',' '

BEGIN {
    OFS=","
}


# HEADER


NR == 1 {

    # Remove ratings_disabled column
    print $1, $2, $3, $4, $5, $6

    next
}


# PROCESS DATA ROWS


{

    # Delete rows with incorrect number of columns
    if (NF != 7)
        next

    # Delete rows with missing values
    for (i = 1; i <= NF; i++) {

        if ($i == "")
            next
    }

    # Delete rows with zero likes/dislikes
    if ($4 == 0 || $5 == 0)
        next

    # Remove time from publish_date
    split($2, dateParts, "T")

    cleanDate = dateParts[1]

    # Convert TRUE/FALSE to True/False
    if ($6 == "TRUE")
        comments = "True"

    else if ($6 == "FALSE")
        comments = "False"

    else
        comments = $6

    # Create cleaned row without ratings_disabled
    row = $1 OFS cleanDate OFS $3 OFS $4 OFS $5 OFS comments

    # Remove duplicate rows
    if (!seen[row]++) {

        print row
    }
}

' "$INPUT_FILE" > "$OUTPUT_FILE"



# SUCCESS MESSAGE


echo "Data cleaning complete."

echo "Cleaned file created: $OUTPUT_FILE"
